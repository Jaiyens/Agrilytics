{
  "name": "agrilytics",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agrilytics — the operating system for the farm. Starts with voice-driven pesticide-use compliance.",
  "scripts": {
    "dev": "concurrently -k -n CLIENT,SERVER -c green,yellow \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "build": "vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@google/genai": "^1.9.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "maplibre-gl": "^4.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "vite": "^5.4.8"
  }
}
