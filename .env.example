# Copy to .env for local dev. NEVER commit your real key.
# Get a free key at https://aistudio.google.com (Get API key).
GEMINI_API_KEY=your-key-here

# Optional. Defaults to gemini-2.5-flash. Use a current flash model — check AI Studio.
# Do NOT use gemini-2.0-flash (retired). Newer 3.x flash models are better.
GEMINI_MODEL=gemini-2.5-flash

# --- Google Maps (farm grounds dashboard) ---
# Maps JavaScript API key from a BILLING-ENABLED Google Cloud project (card on file,
# required even on the free tier). The server reads this and hands it to the client via
# /api/grounds, so NO VITE_ prefix is needed and no rebuild is required when it changes.
# A Maps JS key is client-visible by design, so RESTRICT it in Cloud Console: HTTP
# referrers (localhost:* + your domain) + restrict to the Maps JavaScript API.
GOOGLE_CLOUD_API_KEY=your-maps-key-here
# Optional Cloud Map ID (styled Advanced Markers). Blank -> client uses DEMO_MAP_ID (dev).
GOOGLE_CLOUD_MAP_ID=

# Optional fallback only: a VITE_-prefixed key inlined into the client at build time,
# used if GOOGLE_CLOUD_API_KEY is not set. Most setups can leave these blank.
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_MAP_ID=
