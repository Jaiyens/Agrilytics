# Copy to .env for local dev. NEVER commit your real key.
# Get a free key at https://aistudio.google.com (Get API key).
GEMINI_API_KEY=your-key-here

# Optional. Defaults to gemini-2.5-flash. Use a current flash model — check AI Studio.
# Do NOT use gemini-2.0-flash (retired). Newer 3.x flash models are better.
GEMINI_MODEL=gemini-2.5-flash

# --- Google Maps (farm grounds dashboard) ---
# Client-side key for the satellite grounds map. Because Vite inlines VITE_* vars into
# the public client bundle, this key is NOT secret — you MUST restrict it in Google
# Cloud Console: enable "Maps JavaScript API", enable billing (card on file, required
# even on the free tier), then lock the key to HTTP referrers (localhost:* + your domain)
# and to the Maps JavaScript API only.
VITE_GOOGLE_MAPS_API_KEY=your-maps-key-here

# Optional. A Cloud-created Map ID enables Advanced Markers in production. Leave unset to
# use Google's "DEMO_MAP_ID" (fine for local dev; logs a console notice, not for prod).
VITE_GOOGLE_MAPS_MAP_ID=
